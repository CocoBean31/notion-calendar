<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Calendar</title>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.17/index.global.min.css" rel="stylesheet">

<style>

body{
    margin:40px;
    background:#ffffff;
    font-family:Inter,sans-serif;
    color:#000;
}

.calendar-card{

    max-width:1100px;
    margin:auto;

    border:1px solid #ececec;
    border-radius:16px;

    padding:20px;

    background:white;

    box-shadow:0 2px 10px rgba(0,0,0,.04);

}

.header{

    display:flex;
    justify-content:space-between;
    align-items:center;

    margin-bottom:20px;

}

.header h2{

    margin:0;

    font-size:22px;

    font-weight:600;

}

button{

    border:1px solid #ddd;

    background:white;

    padding:8px 14px;

    border-radius:8px;

    cursor:pointer;

}

button:hover{

    background:#f7f7f7;

}

/* Calendar */

.fc{

    font-size:14px;

    color:black;

}

.fc-toolbar-title{

    font-size:20px !important;

    font-weight:600;

}

.fc-col-header-cell{

    background:white;

    padding:12px 0;

    font-weight:600;

}

.fc-timegrid-slot{

    height:55px;

}

.fc-event{

    border:none !important;

    border-radius:10px !important;

    padding:4px;

    color:black !important;

    font-weight:500;

}

.fc-event-title{

    font-weight:600;

}

.fc-daygrid-day-number,
.fc-col-header-cell-cushion{

    color:black !important;

    text-decoration:none;

}

.fc-timegrid-axis-cushion{

    color:#666;

}

.fc-scrollgrid{

    border-radius:10px;

}

/* Different colours */

.gym{

    background:#d9f2e7 !important;

}

.work{

    background:#dfe8ff !important;

}

.home{

    background:#e8f4d9 !important;

}

</style>
</head>

<body>

<div class="calendar-card">

<div class="header">

<h2>📅 Google Calendar</h2>

<button onclick="window.open('https://calendar.google.com')">
Open Google Calendar
</button>

</div>

<div id="calendar"></div>

</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.17/index.global.min.js"></script>

<script>

document.addEventListener('DOMContentLoaded', function() {

var calendarEl = document.getElementById('calendar');

var calendar = new FullCalendar.Calendar(calendarEl, {

initialView:'timeGridWeek',

headerToolbar:{

left:'',

center:'title',

right:''

},

allDaySlot:true,

slotMinTime:"08:00:00",

slotMaxTime:"20:00:00",

height:"auto",

events:[

{

title:'DFT Teaching',

start:'2026-06-29T09:00:00',

end:'2026-06-29T10:00:00',

className:'work'

},

{

title:'Patient Clinic',

start:'2026-06-30T09:00:00',

end:'2026-06-30T10:30:00',

className:'work'

},

{

title:'Gym',

start:'2026-07-02T07:30:00',

end:'2026-07-02T08:30:00',

className:'gym'

},

{

title:'Meal Prep',

start:'2026-07-01T17:00:00',

end:'2026-07-01T18:00:00',

className:'home'

},

{

title:'CPD Webinar',

start:'2026-07-04T13:00:00',

end:'2026-07-04T14:00:00',

className:'work'

},

{

title:'Dinner with Jess',

start:'2026-07-04T19:00:00',

end:'2026-07-04T20:00:00',

className:'home'

}

]

});

calendar.render();

});

</script>

</body>
</html>
